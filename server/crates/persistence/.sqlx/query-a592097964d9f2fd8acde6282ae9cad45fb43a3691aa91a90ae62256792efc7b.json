  "query": "SELECT\n      ci.contact_inquiry_id\n    , ci.contact_inquiry_ident\n    , ci.dt_created\n    , ci.dt_modified\n    , st.att_pub_ident          \"status\"\n    , ci.first_name\n    , ci.last_name\n    , ci.email\n    , ci.website_given\n    , ci.message\nFROM\n    brochure.contact_inquiry ci\nJOIN\n    brochure.struct_type st\nON\n    ci.status_id = st.struct_type_id\nWHERE\n    contact_inquiry_ident = $1\n;\n",
