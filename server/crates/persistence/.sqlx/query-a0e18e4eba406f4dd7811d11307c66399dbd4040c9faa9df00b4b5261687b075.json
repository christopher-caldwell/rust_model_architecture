{
  "db_name": "PostgreSQL",
  "query": "SELECT\n      l.loan_id\n    , l.loan_ident\n    , l.dt_created\n    , l.dt_modified\n    , l.book_copy_id\n    , l.member_id\n    , NULLIF(l.dt_due, '9999-01-01 00:00:00+00'::TIMESTAMPTZ) AS dt_due\n    , NULLIF(l.dt_returned, '9999-01-01 00:00:00+00'::TIMESTAMPTZ) AS dt_returned\nFROM\n    library.loan l\nWHERE\n    l.member_id = $1\nORDER BY\n      l.dt_created DESC\n    , l.loan_id DESC\n;\n",
