{
  "name": "@library/persistence",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "pgtyped": ". .env && pgtyped generate -c config.json",
    "pgtyped:watch": ". .env && pgtyped generate -w -c config.json",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@library/application": "workspace:*",
    "@library/domain": "workspace:*",
    "@pgtyped/runtime": "^2.4.2",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@pgtyped/cli": "^2.4.3",
    "@types/pg": "^8.11.11",
    "typescript": "^5.8.2"
  }
}
