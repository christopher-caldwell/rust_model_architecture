{
  "db_name": "PostgreSQL",
  "query": "SELECT\n      m.member_id\n    , m.member_ident\n    , m.dt_created\n    , m.dt_modified\n    , st.att_pub_ident \"status\"\n    , m.full_name\n    , m.max_active_loans\nFROM\n    library.member m\nJOIN\n    library.struct_type st\nON\n    m.status_id = st.struct_type_id\nWHERE\n    m.member_id = $1\nAND\n    st.group_name = 'member_status'\nAND\n    st.att_pub_ident IN ('active', 'suspended')\n;\n",
